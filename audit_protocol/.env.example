# Скопируй в .env и заполни:
#   cp .env.example .env

# ── Обязательно ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Опционально (есть дефолты) ───────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.60   # порог уверенности (0.0–1.0)
CONSISTENCY_RUNS=3           # кол-во прогонов для self-consistency
AGENT_ID=main_agent_prod     # идентификатор агента в логах
